# Zurfur local configuration.
# Copy to `.env`. These environment variables override config/<profile>.toml — env always wins.
# Secrets live here only, never in committed config files.

# Selects the config profile loaded from backend/crates/api/src/config/<profile>.toml
ZURFUR_ENV=dev

# Bind address for the axum HTTP server
ZURFUR_HTTP_ADDR=127.0.0.1:8080

# Postgres connection string (matches docker-compose.yml defaults).
# Deliberately unprefixed — sqlx-cli and compile-time-checked query!() read this exact name.
DATABASE_URL=postgres://admin:password@localhost:5432/zurfur

# Tracing filter. Unprefixed by convention (tracing-subscriber EnvFilter).
RUST_LOG=info,zurfur=debug
