# Zurfur local configuration.
# Copy to `.env`. These environment variables override config/<profile>.toml — env always wins.
# Secrets live here only, never in committed config files.

# Selects the config profile loaded from backend/config/<profile>.toml
ZURFUR_ENV=dev

# Bind address for the axum HTTP server (host:port — parsed as a SocketAddr, no scheme)
ZURFUR_HTTP_ADDR=127.0.0.1:8080

# Externally-visible origin (scheme + host + port) used to build OAuth redirect URIs.
ZURFUR_PUBLIC_URL=http://127.0.0.1:8080

# Postgres connection string (matches docker-compose.yml defaults).
# Deliberately unprefixed — sqlx-cli and compile-time-checked query!() read this exact name.
DATABASE_URL=postgres://admin:password@localhost:5432/zurfur

# Tracing filter. Unprefixed by convention (tracing-subscriber EnvFilter).
RUST_LOG=info,zurfur=debug

# --- did:plc minter (ZMVP-49) ---
# DEV-ONLY root key that envelope-encrypts each account's minted did:plc custody
# keys at rest. Base64 of 32 random bytes. A config/env secret is NOT a hardware
# boundary — acceptable only pre-alpha; hardening into a cloud KMS/HSM is the
# URGENT follow-up ZMVP-53, required before any real account is minted. Generate a
# fresh one with:  openssl rand -base64 32
ZURFUR_DID_KEY_ROOT_KEY=ZGV2LW9ubHktcm9vdC1rZXktZG8tbm90LXNoaXAhISE=
# PLC directory. In v1 submission is OFF (no registration against canonical
# plc.directory); flip to true at launch. The endpoint defaults to a LOCAL
# placeholder (http://localhost:2582), deliberately NOT canonical plc.directory —
# canonical must be set explicitly at launch so a stray submit=true can't register
# against the public append-only log by accident.
ZURFUR_PLC_DIRECTORY_SUBMIT=false
# ZMVP-102 stands up a REAL local PLC at this exact endpoint (docker-compose's
# `plc` service) — uncommented on purpose: it's no longer just a placeholder,
# something is actually listening at localhost:2582 once `just up` is running.
# Reconciled onto this ONE endpoint everywhere (the dev PDS below, the minter
# above) rather than a second/different PLC address.
ZURFUR_PLC_DIRECTORY_ENDPOINT=http://localhost:2582

# --- Local PDS + PLC (dev loop; ZMVP-102) ---
# `just up` / `just dev` bring up a real reference PDS (Bluesky's `pds`
# container, speaking the real protocol) plus the local PLC directory it mints
# accounts against (above). Both sit on an `internal: true` Docker network
# (docker-compose.yml `pds_net`) — no default route out, so nothing here can
# reach the public atproto network or canonical plc.directory even by
# accident. Wipe with `just pds-reset` (or `just db-reset`, which now wipes
# everything). See adapter-atproto/CLAUDE.md for the "no PDS in production
# v1" backdrop (DD 26935298) — this PDS is dev-only, never deployed.

# Digest-pinned reference PDS image (github.com/bluesky-social/pds). This
# EXACT literal is shared with ZMVP-103's Rust testcontainers harness (a
# `#[test]` there asserts equality) — bump both together.
ZURFUR_PDS_IMAGE=ghcr.io/bluesky-social/pds@sha256:1fa8bbceabb65d8e1710749b1ea92c1c20a7489ca38da4a0a5f64c0c10a70c29

# THE PDS endpoint config key: adapter-atproto/api (ZMVP-105) and the
# ZMVP-103 test-support crate both name their "where's the PDS" config this
# way — named once, here, so it isn't reinvented per-consumer.
ZURFUR_PDS_ENDPOINT=http://localhost:2583

# Dev-only PDS secrets. Never used past a laptop; regenerate anytime with:
#   openssl rand -hex 32   (JWT secret, PLC rotation key)
#   openssl rand -hex 16   (admin password)
ZURFUR_PDS_JWT_SECRET=30c7c148b04d9f55aa7dd9df2f20cdc98c3717d9b5023468452a615fac6e7af2
ZURFUR_PDS_ADMIN_PASSWORD=a130b53e7f6b61b21307adeb4afaf7da
# The PDS's OWN did:plc signing key (distinct from ZURFUR_DID_KEY_ROOT_KEY
# above, which is Zurfur's *application* custody root — this one belongs to
# the throwaway reference PDS container, not to any Zurfur-minted identity).
ZURFUR_PDS_PLC_ROTATION_KEY=03dc0e1ca38865b469ced6223e5745978fa74d774eed8820d7238fe765619ffd

# Blob upload ceiling for the dev PDS, in bytes. Must sit at/above the
# feed.post lexicon's 100MB (100000000-byte) video cap (ZMVP-104) — a
# lexicon-valid record must never be rejected by the server's own (much
# smaller, 5MB-default) limit.
ZURFUR_PDS_BLOB_UPLOAD_LIMIT=104857600

# Fixture test account `scripts/pds-provision.sh` (and `just pds-provision`)
# create-or-sign-into. `.test` is the handle domain the dev PDS accepts under
# PDS_DEV_MODE — not a real TLD, never resolvable outside this stack.
ZURFUR_PDS_TEST_HANDLE=alice.test
ZURFUR_PDS_TEST_EMAIL=alice@zurfur.test
ZURFUR_PDS_TEST_PASSWORD=c7a74c7607b053b172301a6e

# --- Worktree isolation (secondary checkouts only) ---
# In a `git worktree` you can run a second dev stack in parallel without fighting
# the primary checkout over Postgres/ports. Run `just worktree-init` once inside
# the worktree; it appends a managed block setting these and rewriting the values
# above to unique ports. Leave these unset in the primary checkout (defaults below):
#   COMPOSE_PROJECT_NAME=zurfur     # namespaces containers + the pg_data volume
#   ZURFUR_DB_HOST_PORT=5432        # host port docker-compose maps Postgres to
#   ZURFUR_PROXY_HOST_PORT=8080     # host port for the optional nginx proxy
#   ZURFUR_PDS_HOST_PORT=2583       # host port docker-compose maps the dev PDS to
#   ZURFUR_PDS_ENDPOINT=http://localhost:2583   # kept coherent with the port above
#   ZURFUR_PLC_HOST_PORT=2582       # host port docker-compose maps the local PLC to
#   ZURFUR_PLC_DIRECTORY_ENDPOINT=http://localhost:2582  # kept coherent with the port above
