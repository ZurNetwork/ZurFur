  "query": "\n            INSERT INTO users (id, did, created_at)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (did) DO UPDATE SET did = EXCLUDED.did\n            RETURNING\n                id          AS \"id!\",\n                did         AS \"did!\",\n                created_at  AS \"created_at!: chrono::DateTime<chrono::Utc>\"\n            ",
